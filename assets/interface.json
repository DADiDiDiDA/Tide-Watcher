{
    "interface_version": 2,
    "name": "Tide-Watcher",
    "description": "Tide-Watcher自动化",
    "contact": "",
    "license": "MIT",
    "welcome": "注意看任务介绍！！！！！！",
    "version": "1.3.1",
    
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    
    "task": [
        {
            "name": "🎮 登录游戏",
            "entry": "登陆游戏开始",
            "description": "在游戏加载完成后，自动进入游戏（不可以在游戏内执行欧）"
        },
        {
            "name": "🎁 领取商城免费礼包",
            "entry": "领取商城免费礼包开始",
            "description": "领取商城各类免费礼包"
        },
        {
            "name": "✉️领取邮件奖励",
            "entry": "开始领取邮箱奖励",
            "description": "领取邮件奖励，没有会跳过"
        },
        {
            "name": "🎁 领取签到奖励",
            "entry": "开始领取签到奖励",
            "description": "领取每日签到奖励"
        },
        {
            "name": "⛏️ 矿场领取",
            "entry": "点击矿场",
            "description": "领取矿场资源"
        },
        {
            "name": "🛒 矮人超市购买",
            "entry": "矮人超市购买开始",
            "description": "购买一次矮人超市金币商品并执行一次一键购买（需要预设好购买的物品；请保证货币充足！！！！）"
        },
        {
            "name": "👥 领取友情点",
            "entry": "点击好友图标",
            "description": "领取并赠送友情点"
        },
        {
            "name": "💪 友情点换体力",
            "entry": "点击增加体力图标",
            "description": "使用友情点兑换体力"
        },
        {
            "name": "⛵ 航海",
            "entry": "航海启动",
            "description": "启航航海任务；航海任务为上一次派遣目标"
        },
        {
            "name": "🚢 休伯利安",
            "entry": "休伯利安启动",
            "description": "领取每日休伯利安奖励"
        },
        {
            "name": "⚔️ 刷体力",
            "entry": "进入副本选择",
            "description": "自动刷副本（可在下方选择要刷的副本类型）",
            "option": ["副本选择"]
        },
        {
            "name": "🌊 魔潮扫荡",
            "entry": "魔潮扫荡开始节点",
            "description": "自动扫荡魔潮副本"
        },
        {
            "name": "📦 分解角色",
            "entry": "分解角色开始节点",
            "description": "自动遣散一星二星三星角色，以保证英雄数量不会超出仓库"
        },
        {
            "name": "🐉 公会巨龙",
            "entry": "工会巨龙任务开始",
            "description": "需要昨日挑战过！只会挑战昨日挑战的难度"
        },
        {
            "name": "📋 领取任务奖励第一次",
            "entry": "进入任务界面开始",
            "description": "领取任务奖励；只要完成的都会领取"
        },
        {
            "name": "⚡ 装备升级",
            "entry": "装备升级开始",
            "description": "自动强化装备至4级；如果每日任务没有强化装备任务，就跳过；请保证你有可升级的装备！！！！"
        },
        {
            "name": "🔮 英灵召唤一次",
            "entry": "开始英灵召唤一次任务",
            "description": "自动进行一次英灵召唤，如果每日任务没有召唤一次任务，就跳过"
        },
        {
            "name": "📋 领取任务奖励第二次",
            "entry": "进入任务界面开始",
            "description": "领取任务奖励，只要是完成的都会领取"
        },
        {
            "name": "🏛️ 公会奖励领取",
            "entry": "开始公会奖励领取",
            "description": "领取公会的待领取奖励；不领取工会战奖励！！"
        },
        {
            "name": "🎟️ 通行证奖励领取",
            "entry": "开始进入通行证",
            "description": "通行证奖励领取"
        },
        {
            "name": "⏰ 在线奖励领取",
            "entry": "开始在线奖励领取",
            "description": "领取在线时长奖励"
        },
        {
            "name": "🔄 每周交易所交易",
            "entry": "每周交易所交易开始",
            "description": "每周交易所交易"
        },
        {
            "name": "🗿 泰坦废墟任务",
            "entry": "泰坦废墟任务开始",
            "description": "自动完成泰坦废墟挑战并领取奖励"
        }
    ],

    "option": {
        "副本选择": {
            "type": "select",
            "label": "副本选择",
            "description": "选择要自动刷取的副本类型",
            "default_case": "装备本三",
            "cases": [
                {
                    "name": "装备本一",
                    "label": "装备本一",
                    "description": "刷取装备副本一",
                    "pipeline_override": {
                        "进入副本选择开始": {
                            "next": ["进入装备本-装备一"]
                        }
                    }
                },
                {
                    "name": "装备本二",
                    "label": "装备本二",
                    "description": "刷取装备副本二",
                    "pipeline_override": {
                        "进入副本选择开始": {
                            "next": ["进入装备本-装备二"]
                        }
                    }
                },
                {
                    "name": "装备本三",
                    "label": "装备本三",
                    "description": "刷取装备副本三",
                    "pipeline_override": {
                        "进入副本选择开始": {
                            "next": ["进入装备本-装备三"]
                        }
                    }
                },
                {
                    "name": "神器本",
                    "label": "神器本",
                    "description": "刷取神器副本",
                    "pipeline_override": {
                        "进入副本选择开始": {
                            "next": ["进入神器本"]
                        }
                    }
                }
            ]
        }
    }
}